# Copy this file to `.env.local` (git-ignored) and fill in real values.
# In production, set the same variables in your Vercel project settings.

# Public site URL — used for absolute OG/canonical URLs.
NEXT_PUBLIC_SITE_URL=https://lengocha.vercel.app

# --- Notion "Writing" integration (optional) --------------------------------
# When both are set, the Writing section and /writing/[slug] pages are driven by
# a Notion database. When unset, the site falls back to a hardcoded entry.
#
# 1. Create an internal integration at https://www.notion.so/my-integrations
#    and copy its "Internal Integration Secret" here.
# 2. Create a database with these properties (case-sensitive):
#      Title (title) · Description (rich_text) · Tags (multi_select)
#      Published (checkbox) · Date (date) · Slug (rich_text, optional)
# 3. Open the database → ••• menu → "Connections" → add your integration.
# 4. Copy the database id from its URL (the 32-char id before `?v=`).
NOTION_TOKEN=
NOTION_WRITING_DB_ID=
